{
  "name": "spotify-yt-player",
  "version": "1.0.0",
  "description": "A Spotify-like YouTube Music desktop app",
  "author": "iisuperboyii",
  "main": "electron/main.js",
  "scripts": {
    "dev:react": "npm run dev --prefix renderer",
    "dev:electron": "electron .",
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "build:renderer": "npm run build --prefix renderer",
    "build": "npm run build:renderer && electron-builder --win",
    "dist": "npm run build:renderer && electron-builder --win"
  },
  "build": {
    "appId": "com.iisuperboyii.spotify-yt",
    "productName": "Spotify YT Player",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "win-audio": "^3.0.5"
  }
}
